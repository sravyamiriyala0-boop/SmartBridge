                  <value>&quot;Lazy&quot;</value>
                  <value>&quot;No reasons&quot;</value>
                  <value>&quot;None, i don&apos;t eat comfort food. I just eat when i&apos;m hungry.&quot;</value>
                  <value>&quot;Sad, bored, excited&quot;</value>
                  <value>&quot;survival, bored&quot;</value>
                  <value>&quot;They taste better than other food. They are a pickme up. They are easy to make&quot;</value>
                  <value>&quot;Tired&quot;</value>
                  <value>&quot;Usually if I&apos;m sad or depressed.&quot;</value>
                  <value>&quot;we dont have comfort&quot;</value>
                  <value>&quot;when i am sad or craving&quot;</value>
                  <value>&quot;When i&apos;m  eating with my close friends/ Food smell or look good/ when I feel tired&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Sadness&quot;'>
                  <value>&quot;All of the above; sadness, boredom and confusion &quot;</value>
                  <value>&quot;Anger, sadness&quot;</value>
                  <value>&quot;Bad day, bored, sadness&quot;</value>
                  <value>&quot;boredom and sadness&quot;</value>
                  <value>&quot;Boredom and sadness&quot;</value>
                  <value>&quot;boredom, sadness&quot;</value>
                  <value>&quot;Boredom, sadness&quot;</value>
                  <value>&quot;boredom, sadness &quot;</value>
