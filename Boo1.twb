      <aliases enabled='yes' />
      <column caption='Gender1' datatype='string' name='[Calculation_0586883905634304]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender] = 1 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Male&quot;&#13;&#10;END' />
      </column>
      <column caption='Breakfast1' datatype='string' name='[Calculation_0586883906187265]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [breakfast] = 1 THEN &quot;Cerals&quot;&#13;&#10;ELSE &quot;Donut&quot;&#13;&#10;END' />
      </column>
      <column caption='Health' datatype='string' name='[Calculation_0791668560752640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [fruit_day] &gt;=4&#13;&#10;AND [fries] &lt;=2&#13;&#10;AND [veggies_day]&gt;=4&#13;&#10;AND [exercise]&gt;=1&#13;&#10;THEN &quot;Healthy&quot;&#13;&#10;ELSE &quot;Unhealthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_0791668563931137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1]=&quot;Veggies Day&quot; THEN [veggies_day]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&quot;Vitamins&quot; THEN [vitamins]&#13;&#10;ELSE [fruit_day]&#13;&#10;END' />
      </column>
      <column caption='Calculation2' datatype='real' name='[Calculation_0791668566949890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;Thai_Food&quot; THEN [thai_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2] =&quot;Indian_Food&quot; THEN [indian_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2] =&quot;Greek_Food&quot; THEN [greek_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2]=&quot;Italian_Food&quot; THEN [italian_food]&#13;&#10;ELSE [persian_food]&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Comfort Food Reasons (group) 1]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[comfort_food_reasons]' new-bin='true'>
          <bin default-name='false' value='&quot;Boredom&quot;'>
            <value>&quot;boredom&quot;</value>
            <value>&quot;Boredom&quot;</value>
            <value>&quot;Boredom comfort hunger&quot;</value>
            <value>&quot;Boredom usually&quot;</value>
            <value>&quot;Boredom, anger and just being hungry in general.&quot;</value>
            <value>&quot;Boredom, anger, drunkeness&quot;</value>
            <value>&quot;boredom, anger, happy&quot;</value>
            <value>&quot;Boredom, being in your period, and long bus rides for softball&quot;</value>
            <value>&quot;Boredom, hunger, snacking.&quot;</value>
            <value>&quot;Boredom, laziness, anger&quot;</value>
            <value>&quot;Boredom, lazyniss &quot;</value>
            <value>&quot;Boredom. Celebration.&quot;</value>
            <value>&quot;Friends, environment and boredom&quot;</value>
            <value>&quot;Hunger and Boredom&quot;</value>
            <value>&quot;Hunger, boredom&quot;</value>
            <value>&quot;I usually only eat comfort foods when I am bored. I will also eat them when I am happy to celebrate and then when I am sad to comfort me.&quot;</value>
            <value>&quot;loneliness, homework, boredom &quot;</value>
            <value>&quot;Mostly boredom&quot;</value>
            <value>&quot;stres, boredom, and nighttime&quot;</value>
            <value>&quot;they are yummy, my boyfriend sometimes makes me sad, boredom&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Happiness&quot;'>
