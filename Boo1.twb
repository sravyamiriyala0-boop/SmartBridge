          <datasource-dependencies datasource='Parameters'>
            <column caption='Parameter 2' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Indian_food&quot;'>
              <calculation class='tableau' formula='&quot;Indian_food&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1ajmkla04646dh1dlp1b30blyxzz'>
            <column caption='Gender1' datatype='string' name='[Calculation_0586883905634304]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Gender] = 1 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Male&quot;&#13;&#10;END' />
            </column>
            <column caption='Health' datatype='string' name='[Calculation_0791668560752640]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  [fruit_day] &gt;=4&#13;&#10;AND [fries] &lt;=2&#13;&#10;AND [veggies_day]&gt;=4&#13;&#10;AND [exercise]&gt;=1&#13;&#10;THEN &quot;Healthy&quot;&#13;&#10;ELSE &quot;Unhealthy&quot;&#13;&#10;END' />
            </column>
            <column caption='Calculation2' datatype='real' name='[Calculation_0791668566949890]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;Thai_Food&quot; THEN [thai_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2] =&quot;Indian_Food&quot; THEN [indian_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2] =&quot;Greek_Food&quot; THEN [greek_food]&#13;&#10;ELSEIF [Parameters].[Parameter 2]=&quot;Italian_Food&quot; THEN [italian_food]&#13;&#10;ELSE [persian_food]&#13;&#10;END' />
